{
  "name": "essenzamodels",
  "version": "1.0.6",
  "author": "sb",
  "type": "module",
  "description": "Corporate Communication Platform",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/optimize-for-low-ram.js && concurrently -k -n \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development VITE_APP_VERSION=1.0.0 electron .\"",
    "build": "node scripts/optimize-assets.js && vite build && node scripts/analyze-bundle.js",
    "electron": "node scripts/optimize-for-low-ram.js && electron .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --publish always",
    "analyze": "node scripts/optimize-assets.js && node scripts/analyze-bundle.js",
    "clean": "rm -rf dist node_modules/.vite",
    "deploy": "node scripts/deploy.js",
    "deploy:minor": "node scripts/deploy.js minor",
    "deploy:major": "node scripts/deploy.js major",
    "auto-deploy": "node scripts/auto-deploy.js",
    "ship": "node scripts/auto-deploy.js patch",
    "ship:minor": "node scripts/auto-deploy.js minor",
    "ship:major": "node scripts/auto-deploy.js major"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "driver.js": "^1.4.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vueuse/core": "^10.11.1",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "lucide-vue-next": "^0.344.0",
    "pinia": "^2.1.7",
    "postcss": "^8.4.38",
    "radix-vue": "^1.9.0",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.2",
    "typescript": "^5.3.3",
    "vite": "^5.2.6",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue-sonner": "^2.0.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.essenzamodels.monitor",
    "productName": "essenzamodels",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "public",
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/electron-updater/**/*",
      "node_modules/active-win/**/*",
      "node_modules/driver.js/**/*",
      "!src/**/*",
      "!scripts/**/*",
      "!*.md",
      "!*.log",
      "!.git/**/*",
      "!.vscode/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Santibrito",
      "repo": "essenza-app",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/essenza.ico"
    },
    "mac": {
      "category": "public.app-category.business",
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/icons.icns"
    },
    "dmg": {
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "shortcutName": "ESSENZA MODELS",
      "uninstallDisplayName": "Desinstalar ESSENZA MODELS",
      "installerIcon": "public/essenza.ico",
      "uninstallerIcon": "public/essenza.ico",
      "differentialPackage": true,
      "allowElevation": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": "ESSENZA MODELS",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
